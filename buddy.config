{
  "secret_env_path": "secret.env",
  "default_model": "openai/gpt-4o-mini-2024-07-18",
  "max_tokens": 4000,
  "temperature": 0.7,
  "top_p": 0.9,
  "top_k": 50,
  "frequency_penalty": 0.5,
  "presence_penalty": 0.5,
  "repetition_penalty": 1.2,
  "min_p": 0.1,
  "top_a": 0.8,
  "seed": 42,
  "logit_bias": {"token1": -1, "token2": 2},
  "logprobs": true,
  "top_logprobs": 5,
  "response_format": {"type": "json_object"},
  "stop": [1, 2, 3]
}
